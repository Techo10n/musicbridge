# ── Supabase ──────────────────────────────────────────────────────────────────
# Found at: Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ── Spotify ───────────────────────────────────────────────────────────────────
# Create an app at: https://developer.spotify.com/dashboard
# Add redirect URI: musicbridge://spotify-callback
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=

# ── Google / YouTube Music ────────────────────────────────────────────────────
# Create OAuth 2.0 credentials at: https://console.cloud.google.com
# Application type: iOS (for iOS) or Android (for Android)
# Add redirect URI: musicbridge://youtube-callback
EXPO_PUBLIC_GOOGLE_CLIENT_ID=

# ── Apple Music ───────────────────────────────────────────────────────────────
# Requires Apple Developer account with MusicKit enabled
# APPLE_TEAM_ID: Found in your Apple Developer account → Membership
EXPO_PUBLIC_APPLE_TEAM_ID=
# URL of your hosted MusicKit JS auth page (see lib/appleMusic.ts for details)
EXPO_PUBLIC_APPLE_MUSIC_AUTH_URL=
# Developer Token JWT (server-generated using your MusicKit private key)
# ⚠️  For production, generate this server-side — do NOT expose your private key
EXPO_PUBLIC_APPLE_DEVELOPER_TOKEN=
